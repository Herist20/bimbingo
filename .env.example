# =============================================================
# Public (boleh ter-expose ke browser)
# =============================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================
# Server-only — JANGAN expose ke browser
# =============================================================
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-SECRET-KEY"

# Database URL (untuk migrasi & dump backup). Opsional di app runtime.
# SUPABASE_DB_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# Telemetry Next.js
NEXT_TELEMETRY_DISABLED="1"

